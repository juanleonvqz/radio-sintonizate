---
import Base              from '../layouts/Base.astro'
import Header            from '../components/Header.astro'
import DescriptionBanner from '../components/DescriptionBanner.astro'
import Player            from '../components/Player.astro'
import AdminPanel        from '../components/AdminPanel.astro'
import Footer            from '../components/Footer.astro'
import '../styles/global.css'
---

<Base>

  <Header />
  <DescriptionBanner />

  <main>
    <div class="mh">
      <h2 class="mtitle">Episodios</h2>
      <div class="mh-right">
        <span class="ecount" id="ecount"></span>
        <div class="search-box">
          <svg class="search-ico" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            id="search-inp"
            class="search-inp"
            type="search"
            placeholder="Buscar…"
            autocomplete="off"
            autocorrect="off"
            spellcheck="false"
          />
          <button class="search-clear" id="search-clear" aria-label="Limpiar" style="display:none">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Episodes are rendered client-side by src/scripts/grid.ts -->
    <div class="grid" id="grid">
      <div class="state-box">
        <div class="state-ico"><div class="spinner"></div></div>
        <h3>Cargando episodios…</h3>
        <p>Conectando con Radio Sintonízate</p>
      </div>
    </div>
  </main>

  <Footer />

  <Player />
  <AdminPanel />
  <div id="toast"></div>

  <!-- Episode detail modal -->
  <div id="ep-modal">
    <div id="ep-modal-backdrop"></div>
    <div id="ep-modal-sheet">
      <button id="ep-modal-close" aria-label="Cerrar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div id="ep-modal-inner"></div>
    </div>
  </div>

  <!-- Single entry point — Astro bundles and tree-shakes everything -->
  <script>
    import '../scripts/app'
  </script>

</Base>