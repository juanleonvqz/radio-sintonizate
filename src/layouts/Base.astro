---
interface Props {
  title?:       string
  description?: string
  ogImage?:     string
}
const {
  title       = 'Radio Sintonízate · IES El Mayorazgo',
  description = 'La radio oficial del IES El Mayorazgo, La Orotava, Tenerife. Programas, podcasts y emisiones del alumnado.',
  ogImage     = '/logos/Logo_radio_sintonizate_White.jpg',
} = Astro.props

const siteUrl  = 'https://radiosintonizate.com'
const fullUrl  = Astro.url?.href ?? siteUrl
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <!-- ── PRIMARY META ── -->
  <title>{title}</title>
  <meta name="description"        content={description} />
  <meta name="language"           content="es" />
  <meta name="robots"             content="index, follow" />
  <meta name="author"             content="IES El Mayorazgo, La Orotava, Tenerife" />
  <meta name="keywords"           content="radio escolar, IES El Mayorazgo, La Orotava, Tenerife, Canarias, podcast, alumnos" />

  <!-- ── OPEN GRAPH (WhatsApp, Facebook, Telegram) ── -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={fullUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={siteUrl + ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height"content="630" />
  <meta property="og:locale"      content="es_ES" />
  <meta property="og:site_name"   content="Radio Sintonízate" />

  <!-- ── TWITTER / X CARD ── -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={siteUrl + ogImage} />

  <!-- ── PWA / MOBILE ── -->
  <meta name="theme-color"                     content="#F5F0E8" />
  <meta name="mobile-web-app-capable"          content="yes" />
  <meta name="apple-mobile-web-app-capable"    content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title"      content="Radio Sintonízate" />

  <!-- ── ICONS ── -->
  <link rel="icon"          type="image/jpeg" href="/logos/Logo_radio_sintonizate_White.jpg" />
  <link rel="shortcut icon" type="image/jpeg" href="/logos/Logo_radio_sintonizate_White.jpg" />
  <link id="pwa-manifest"   rel="manifest" />
  <link id="apple-icon"     rel="apple-touch-icon" href="/logos/Logo_radio_sintonizate_White.jpg" />

  <!-- ── CANONICAL ── -->
  <link rel="canonical" href={siteUrl} />
  <link rel="sitemap"   href="/sitemap-index.xml" />

  <!-- ── DNS PREFETCH — resolves Supabase DNS early ── -->
  <link rel="dns-prefetch" href="https://vyjftrivoolvmfkopogh.supabase.co" />
  <link rel="preconnect"   href="https://vyjftrivoolvmfkopogh.supabase.co" />

  <!-- ── PRELOAD key images — browser fetches them immediately ── -->
  <link rel="preload" as="image" href="/logos/Logo_radio_sintonizate_White.jpg" />
  <link rel="preload" as="image" href="/logos/Logo_IES_ELMayorazgo_White.png" />

  <!-- ── FONTS ── -->
  <!-- Option A (default): Google Fonts CDN — easy, no setup needed -->
  <!-- To switch to self-hosted (faster in Spain), see Option B below -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:wght@400;700&family=Karla:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <!--
    Option B: Self-hosted fonts (run download-fonts.sh first, then swap):
    <link rel="stylesheet" href="/src/styles/fonts.css" />
  -->

  <!-- ── THEME — must run before paint to avoid flash ── -->
  <script is:inline>
    (function() {
      if (localStorage.getItem('rm-theme') === 'dark') {
        document.documentElement.classList.add('dark-pending')
      } else {
        document.documentElement.classList.add('light-pending')
      }
    })()
  </script>
  <style is:inline>
    html.light-pending body { background: #F5F0E8; color: #1A1108; }
    html.dark-pending  body { background: #0C0906; color: #F0E6CC; }
  </style>
</head>
<body>
  <slot />
  <script is:inline>
    const html = document.documentElement
    if (html.classList.contains('light-pending')) {
      html.classList.remove('light-pending')
      document.body.classList.add('light')
    } else if (html.classList.contains('dark-pending')) {
      html.classList.remove('dark-pending')
    }
  </script>
</body>
</html>