---
interface Props {
  title?: string
}
const { title = 'Radio Sintonízate · IES El Mayorazgo' } = Astro.props
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0C0906" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Radio Sintonízate" />
  <meta name="description" content="La radio oficial del IES El Mayorazgo, La Orotava, Tenerife." />
  <link id="pwa-manifest" rel="manifest" />
  <link id="apple-icon"   rel="apple-touch-icon" />
  <title>{title}</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:wght@400;700&family=Karla:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <!-- Inline theme script — must run before paint to avoid flash of wrong theme -->
  <script is:inline>
    (function() {
      if (localStorage.getItem('rm-theme') === 'light') {
        document.documentElement.classList.add('light-pending')
      }
    })()
  </script>
  <style is:inline>
    /* Apply light theme to html before body is available */
    html.light-pending body { background: #F5F0E8; color: #1A1108; }
  </style>
</head>
<body>
  <slot />
  <!-- Remove pending class after body is available -->
  <script is:inline>
    if (document.documentElement.classList.contains('light-pending')) {
      document.documentElement.classList.remove('light-pending')
      document.body.classList.add('light')
    }
  </script>
</body>
</html>
