---
// Footer — logos swap automatically with light/dark mode via theme.ts
// Uses .school-logo-img class so theme.ts can find and swap them
---

<footer>
<div class="footer-inner">

  <!-- ── LOGOS ROW ── -->
  <div class="footer-logos">

    <!-- Radio Sintonízate -->
    <a class="footer-logo-block" href="/" aria-label="Radio Sintonízate">
      <img
        class="footer-logo-img radio-logo-img"
        src="/logos/Logo_radio_DEGRADADOS.jpg"
        alt="Radio Sintonízate"
      />
      <div class="footer-logo-info">
        <span class="footer-logo-name">Radio Sintonízate</span>
        <span class="footer-logo-sub">La radio del IES El Mayorazgo</span>
      </div>
    </a>

    <div class="footer-logo-divider"></div>

    <!-- IES El Mayorazgo -->
    <a
      class="footer-logo-block"
      href="https://www3.gobiernodecanarias.org/medusa/edublog/ieselmayorazgo/"
      target="_blank"
      rel="noopener"
      aria-label="IES El Mayorazgo"
    >
      <img
        class="footer-logo-img school-logo-img"
        src="/logos/Logo_IES_ELMayorazgo_White.png"
        alt="IES El Mayorazgo"
      />
      <div class="footer-logo-info">
        <span class="footer-logo-name">IES El Mayorazgo</span>
        <span class="footer-logo-sub">La Orotava, Tenerife</span>
      </div>
    </a>

  </div>

  <!-- ── LINKS ── -->
  <div class="footer-links">
    <a class="flink" href="https://www3.gobiernodecanarias.org/medusa/edublog/ieselmayorazgo/" target="_blank" rel="noopener">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Web de nuestro centro
    </a>
    <a class="flink" href="https://sites.google.com/canariaseducacion.es/ieselmayorazgo/inicio?authuser=0" target="_blank" rel="noopener">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      Revista del IES El Mayorazgo
    </a>
    <a class="flink" href="https://www.instagram.com/ieselmayorazgo/reels/" target="_blank" rel="noopener">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      Instagram
    </a>
    <button class="flink" id="rss-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      Feed RSS / Podcast
    </button>
  </div>

  <!-- ── BOTTOM ── -->
  <div class="footer-bottom">
    <div class="footer-contact">
      Contacta con nosotros en
      <a href="mailto:38010979@gobiernodecanarias.org">38010979@gobiernodecanarias.org</a>
    </div>
    <div class="footer-copy">© Radio Sintonízate · IES El Mayorazgo · La Orotava, Tenerife</div>
  </div>

</div>
</footer>